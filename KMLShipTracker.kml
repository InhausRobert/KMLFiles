    <Placemark>
      <name>Ship 1 MSC DOMNA X</name>
      <description>
        <![CDATA[
          <h1>CDATA Tags are useful!</h1>
          <p><font color="red">Text is <i>more readable</i> and 
          <b>easier to write</b> when you can avoid using entity 
          references.</font></p>
        ]]>
      </description>
<styleUrl>#Pin1</styleUrl>
      <Point>
        <coordinates>-12.8,49.74,0</coordinates>
      </Point>
    </Placemark>

